strict digraph {
    idCar1 [node_type=entity, root=root, lexicon_key=idCar];
    idHouse1 [lexicon_key=idHouse];
    red [node_type=property, lexicon_key=red];
    small [lexicon_key=small];

    idCar1 -> red [label=idColor, edge_type=property, lexicon_key=idColor];
    idCar1 -> small [label=idSize, lexicon_key=idSize];
    idCar1 -> idHouse1 [label=isNear, edge_type=relationship, lexicon_key=isNear];
}
